# Firebase Configuration
# Get these values from Firebase Console: Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# Supabase Configuration (for database only)
# Get these from Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Database URL (for migrations — Supabase Dashboard > Project Settings > Database > Connection string)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# OpenAI Configuration (Server-side only, use Vercel secrets instead)
# Do NOT commit real API keys - use environment secrets in production
OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Pexels (for words images – Turkish search). Get key: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Firebase Admin (server) – required for admin API auth
# Option A: Service account JSON path
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Option B: Env vars (from Firebase Console > Project Settings > Service Accounts)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin panel password (default: Wealthy*520 if not set)
# Frontend (admin giriş ekranı): VITE_ADMIN_PASSWORD
# Backend (API doğrulama): ADMIN_PASSWORD veya VITE_ADMIN_PASSWORD
# VITE_ADMIN_PASSWORD=Wealthy*520
